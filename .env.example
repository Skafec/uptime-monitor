# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_your_api_key
# Sender for alert emails. Must be on a domain verified in Resend.
# Falls back to onboarding@resend.dev (owner-only delivery) if unset.
RESEND_FROM="UptimeWatch <alerts@uptimewatchhq.com>"

# Stripe
STRIPE_SECRET_KEY=sk_live_your_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id

# Cron security
CRON_SECRET=your-random-secret-string-here

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
